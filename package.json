{
  "name": "meesho-lister",
  "version": "1.0.0",
  "description": "Automated Meesho product listing agent",
  "type": "module",
  "scripts": {
    "start": "concurrently \"node src/server/index.js\" \"vite\" --names \"server,client\" --prefix-colors \"cyan,magenta\"",
