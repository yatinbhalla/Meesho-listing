# ─── Meesho Supplier Credentials ───────────────────────────────────────────────
# Your supplier.meesho.com login email and password.
# These are ONLY used by Playwright on your local machine — never sent anywhere else.
MEESHO_EMAIL=you@example.com
MEESHO_PASSWORD=your_password_here

# ─── Gemini API Key ─────────────────────────────────────────────────────────────
# Get yours at https://aistudio.google.com/app/apikey
# Used ONLY to generate product text (name, description). No images are ever sent.
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Gemini Model (optional) ────────────────────────────────────────────────────
# By default the app auto-tries a list of models until one works for your key.
# Run "node test/list-models.js" to see exactly which models you can use.
# Set this only if you want to pin to a specific model.
# GEMINI_MODEL=gemini-2.0-flash-lite

# ─── AI Navigation (optional) ───────────────────────────────────────────────────
# When a recorded selector fails at run time, Gemini looks at the page and
# suggests the right element. Default: enabled. Set to "false" to disable and
# fall straight to the manual recovery overlay.
# AI_NAVIGATION_ENABLED=true

# ─── Server Config (optional — defaults shown) ──────────────────────────────────
PORT=3001
